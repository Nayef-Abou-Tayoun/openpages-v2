# GRC MCP Server Configuration
#
# This file contains all configuration options for the GRC MCP Server.
# Settings marked as [MANDATORY] must be configured for the server to start.
# Settings marked as [OPTIONAL] have sensible defaults and can be omitted.

# ============================================================================
# MANDATORY SETTINGS - These MUST be configured
# ============================================================================

# [MANDATORY] OpenPages Base URL
# Base URL for OpenPages API
# - Standard OpenPages: https://your-openpages-instance.com
# - CP4D: https://cpd-zen-ns.apps.example.com/openpages-instance-name (include the full path)
OPENPAGES_BASE_URL=https://your-openpages-instance.com

# [MANDATORY] Authentication Type
# Options: "basic" or "bearer"
# - "basic": Use username/password for basic authentication
# - "bearer": Use API key for IBM Cloud IAM/MCSP, OR username/password for CP4D
OPENPAGES_AUTHENTICATION_TYPE=bearer

# [MANDATORY for basic auth] Basic Authentication Credentials
# Required when OPENPAGES_AUTHENTICATION_TYPE=basic
OPENPAGES_USERNAME=
OPENPAGES_PASSWORD=

# [MANDATORY for bearer auth] Bearer Authentication Settings
# Required when OPENPAGES_AUTHENTICATION_TYPE=bearer
OPENPAGES_AUTHENTICATION_URL=

# [MANDATORY for IBM Cloud/MCSP bearer auth] API Key
# Required for IBM Cloud IAM/MCSP authentication
OPENPAGES_APIKEY=

# [MANDATORY for CP4D bearer auth] CP4D Credentials
# Required when using CP4D (detected by /icp4d-api/v1/authorize in auth URL)
# OPENPAGES_USERNAME=cpadmin
# OPENPAGES_PASSWORD=your_password

# Example CP4D Configuration:
# OPENPAGES_AUTHENTICATION_TYPE=bearer
# OPENPAGES_BASE_URL=https://cpd-zen-ns.apps.ajk-cognos.cp.fyre.ibm.com/openpages-openpagesinstance-with-25
# OPENPAGES_USERNAME=cpadmin
# OPENPAGES_PASSWORD=your_password
# OPENPAGES_AUTHENTICATION_URL=https://cpd-zen-ns.apps.ajk-cognos.cp.fyre.ibm.com/icp4d-api/v1/authorize
# SSL_VERIFY=false

# ============================================================================
# OPTIONAL SETTINGS - These have sensible defaults
# ============================================================================

# Application Settings (Optional)
APP_NAME=grc-mcp-server
DEBUG=false
SERVER_MODE=remote

# Server Settings (Optional)
HOST=0.0.0.0
PORT=8000

# SSL Settings (Optional - defaults to true for security)
# Set to false for development/test environments with self-signed certificates
# WARNING: Setting to false disables SSL certificate verification (security risk in production)
# Common SSL errors that may require SSL_VERIFY=false:
#   - CERTIFICATE_VERIFY_FAILED
#   - Self-signed certificate
#   - Certificate hostname mismatch
SSL_VERIFY=true

# Logging Configuration (Optional)
# LOG_LEVEL: Logging verbosity level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=INFO

# LOG_FORMAT: Log output format
# Options: json, text (default: json)
LOG_FORMAT=json

# LOG_FILE: Path to log file (optional, disabled by default)
# Example: logs/grc-mcp-server.log or /var/log/grc-mcp-server.log
# LOG_FILE=logs/grc-mcp-server.log

# LOG_MAX_BYTES: Max log file size before rotation in bytes (default: 10485760 = 10MB)
LOG_MAX_BYTES=10485760

# LOG_BACKUP_COUNT: Number of backup log files to keep (default: 5)
LOG_BACKUP_COUNT=5

# Observability Settings (Optional - defaults to false)
# Enable observability features (metrics, tracing)
OBSERVABILITY_ENABLED=false

# Metrics Configuration (Optional - defaults to false)
# Metrics are exposed on the main server port at /metrics endpoint
METRICS_ENABLED=false

# Distributed Tracing Configuration (Optional - defaults to false)
TRACING_ENABLED=false
# OTLP_ENDPOINT: OpenTelemetry collector endpoint (required if tracing enabled)
# OTLP_ENDPOINT=http://localhost:4318
# CONSOLE_TRACING: Export traces to console for debugging (default: false)
CONSOLE_TRACING=false

# Rate Limiting Configuration (Optional - defaults to false)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST_SIZE=10

# Authentication Framework (Optional - defaults to true)
AUTH_ENABLED=true

# Object Types Configuration (Optional)
# Path to object types configuration file (default: src/app/config/object_types.json)
OBJECT_TYPES_CONFIG_PATH=src/app/config/object_types.json

# Currency Configuration (Optional)
# DEFAULT_CURRENCY: ISO 4217 currency code (e.g., USD, EUR, GBP, INR)
# Used as default when currency is not specified for CURRENCY_TYPE fields (default: USD)
DEFAULT_CURRENCY=USD

# Token Optimization Settings (Optional - Phase 2)
# SCHEMA_CACHE_MAX_SIZE: Maximum number of type definition schemas to cache (LRU)
# Default: 20 schemas
# Increase for environments with many object types, decrease to reduce memory usage
SCHEMA_CACHE_MAX_SIZE=20

# SCHEMA_CACHE_TTL: Schema cache time-to-live in seconds
# Default: 3600 (1 hour)
# Schemas are static but this ensures fresh data periodically
# Set to 0 to disable TTL (cache indefinitely until evicted)
SCHEMA_CACHE_TTL=3600

# ENABLE_MINIMAL_SCHEMA_MODE: Enable minimal schema mode for resource schemas
# Default: true
# Minimal mode returns only field names and types (87% smaller)
# Use for initial exploration, then switch to compact/full as needed
ENABLE_MINIMAL_SCHEMA_MODE=true

# CACHE_QUERY_EXAMPLES: Cache query examples with schemas
# Default: true
# Query examples are deterministic and can be cached
# Reduces CPU usage for schema generation
CACHE_QUERY_EXAMPLES=true

# MCP Session Management (Optional - Streamable HTTP transport, spec 2025-03-26)
# MCP_SESSION_ENFORCEMENT: Require Mcp-Session-Id header on all non-initialize requests
# Default: false (set to true for production-safety; enforces session lifecycle per spec)
# Set to false to allow clients that do not support session headers (e.g., MCP Inspector)
MCP_SESSION_ENFORCEMENT=false

# MCP_SESSION_TTL: Session time-to-live in seconds (default: 3600 = 1 hour)
# Sessions inactive for longer than this will be automatically cleaned up
# Prevents memory leaks from abandoned sessions
MCP_SESSION_TTL=3600

# MCP_SESSION_MAX_COUNT: Maximum number of concurrent sessions (default: 1000)
# New session requests will be rejected with 503 when limit is reached
# Prevents unbounded memory growth in high-traffic scenarios
MCP_SESSION_MAX_COUNT=1000

# MCP_SESSION_CLEANUP_INTERVAL: How often to run cleanup task in seconds (default: 300 = 5 minutes)
# Background task periodically removes expired sessions and orphaned SSE queues
# Lower values = more frequent cleanup but higher CPU usage
MCP_SESSION_CLEANUP_INTERVAL=300