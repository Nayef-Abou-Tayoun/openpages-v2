%% OpenPages MCP Server - Local Mode Architecture
%% This is a Mermaid diagram that can be rendered in GitHub, VS Code, or online tools

graph TB
    subgraph "Client Layer"
        A1[AI Agents<br/>Custom Applications]
        A2[MCP Inspector<br/>Testing Tool]
        A3[IBM Bob<br/>AI Assistant]
    end
    
    subgraph "Local Process - Python Virtual Environment"
        B[Python Process<br/>main.py --mode local]
        
        subgraph "stdio Transport"
            C1[stdin Reader<br/>JSON-RPC Requests]
            C2[stdout Writer<br/>JSON-RPC Responses]
            C3[stderr Logger<br/>Application Logs]
        end
        
        subgraph "MCP Server Core"
            D1[Request Processor]
            D2[Tool Handlers]
            D3[Schema Builder]
        end
        
        subgraph "OpenPages Client"
            E1[REST API Client]
            E2[Authentication]
            E3[Session Management]
        end
    end
    
    subgraph "Backend Layer"
        F[IBM OpenPages<br/>GRC Platform<br/>REST API]
    end
    
    A1 -->|MCP Protocol<br/>stdio/JSON-RPC| B
    A2 -->|MCP Protocol<br/>stdio/JSON-RPC| B
    A3 -->|MCP Protocol<br/>stdio/JSON-RPC| B
    
    B --> C1
    B --> C2
    B --> C3
    
    C1 --> D1
    D1 --> D2
    D2 --> D3
    D3 --> E1
    
    E1 --> E2
    E2 --> E3
    E3 -->|HTTPS/REST| F
    
    C2 -.->|Responses| A1
    C2 -.->|Responses| A2
    C2 -.->|Responses| A3
    
    style A1 fill:#e1f5ff
    style A2 fill:#e1f5ff
    style A3 fill:#e1f5ff
    style B fill:#e8f5e9
    style C1 fill:#fff9c4
    style C2 fill:#fff9c4
    style C3 fill:#fff9c4
    style F fill:#f3e5f5