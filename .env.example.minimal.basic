# Minimal configuration for Basic Authentication
# Copy this to .env and fill in your values

# OpenPages Instance (REQUIRED)
OPENPAGES_BASE_URL=https://your-openpages-instance.com

# Basic Authentication (REQUIRED)
OPENPAGES_AUTHENTICATION_TYPE=basic
OPENPAGES_USERNAME=your_username
OPENPAGES_PASSWORD=your_password

# SSL Verification (set to false for self-signed certificates in dev/test)
SSL_VERIFY=true