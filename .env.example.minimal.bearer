# Minimal configuration for Bearer Token Authentication
# Copy this to .env and fill in your values
#
# IMPORTANT: Bearer authentication is for IBM Cloud SaaS, MCSP, and CP4D deployments.
# For IBM Cloud HOSTED or ON-PREMISES instances, use .env.example.minimal.basic instead.

# OpenPages Instance (REQUIRED)
OPENPAGES_BASE_URL=https://your-openpages-instance.com

# Bearer Token Authentication (REQUIRED)
OPENPAGES_AUTHENTICATION_TYPE=bearer

# For IBM Cloud SaaS (NOT for IBM Cloud hosted instances)
OPENPAGES_AUTHENTICATION_URL=https://iam.cloud.ibm.com/identity/token
OPENPAGES_APIKEY=your_api_key

# For MCSP (use these instead of IBM Cloud SaaS settings above)
# OPENPAGES_AUTHENTICATION_URL=https://account-iam.platform.saas.ibm.com/api/2.0/services/your-service-id/apikeys/token
# OPENPAGES_APIKEY=your_api_key

# For CP4D (use these instead of IBM Cloud SaaS settings above)
# OPENPAGES_AUTHENTICATION_URL=https://your-cp4d-instance.com/icp4d-api/v1/authorize
# OPENPAGES_USERNAME=your_username
# OPENPAGES_PASSWORD=your_password
# OPENPAGES_INSTANCE_NAME=your_instance_name

# SSL Verification (set to false for self-signed certificates in dev/test)
SSL_VERIFY=true